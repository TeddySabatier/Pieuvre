# Copy to .env — never commit .env

# --- Credential profiles (see config/credential-profiles.example.yaml) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=
NOTION_TOKEN_MAIN=

# --- LLM (reasoning tiers — see config/llm-tiers.example.yaml) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Embeddings (cloud API — see RESEARCH §4) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=

# --- Admin (global — costly ops: rescan, bulk admin CLI) ---
# Comma-separated Slack user IDs
PIEUVRE_ADMIN_SLACK_IDS=

# --- Retention (optional — defaults in docs/RETENTION.md) ---
# PIEUVRE_RETENTION_TRACES_DAYS=90
# PIEUVRE_RETENTION_CONVERSATION_STATE_DAYS=30

# --- App ---
DATABASE_URL=postgres://pieuvre:pieuvre@postgres:5432/pieuvre
NODE_ENV=production
